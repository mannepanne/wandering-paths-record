# Environment Variables for Wandering Paths
#
# For the full reference (including Cloudflare Worker secrets set via
# `wrangler secret put`), see REFERENCE/environment-setup.md.
#
# No Supabase variables: the database is Cloudflare D1, bound to the
# Worker server-side — no client-side database config exists.

# Admin Authentication (client-side — used to show/hide admin UI)
VITE_AUTHORIZED_ADMIN_EMAIL=your_admin_email@example.com

# Claude API (used by the local API server, server.cjs, during dev)
VITE_CLAUDE_API_KEY=your_anthropic_api_key

# Google Maps — geocoding and place lookups
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Mapbox — interactive map display
VITE_MAPBOX_ACCESS_TOKEN=your_mapbox_access_token

# Production (Cloudflare Workers) uses these as Worker secrets, not VITE_ vars:
#   wrangler secret put CLAUDE_API_KEY
#   wrangler secret put GOOGLE_MAPS_API_KEY
#   wrangler secret put MAPBOX_ACCESS_TOKEN
